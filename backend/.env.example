# SonicTrace Backend Environment Variables
# Copy to .env and fill in your values

# Required: Gemini API key for LLM features (summary + RAG chat)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: HuggingFace token (for gated models)
HF_TOKEN=

# Optional: Whisper model size (tiny/base/small/medium/large)
WHISPER_MODEL_SIZE=medium

# Optional: Device (cuda / cpu)
DEVICE=cuda

# Optional: Audio upload directory
AUDIO_DIR=data/audio

# Optional: SQLite database path
SONIC_DB_PATH=data/sonic_trace.db

# Optional: ChromaDB persistence directory
CHROMA_DIR=data/chroma_db
